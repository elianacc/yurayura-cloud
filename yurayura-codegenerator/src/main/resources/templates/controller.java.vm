package ${package.Controller};

import org.springframework.util.ObjectUtils;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.beans.factory.annotation.Autowired;
import ${package.Service}.${table.serviceName};
import ${packageParentPath}.dto.IdDto;
import ${packageParentPath}.entity${entityPackagePath}#if(${entity.toLowerCase().startsWith("sys")})${entity.toLowerCase().substring(3)}#else${entity.toLowerCase()}#end.${entity}
import ${packageParentPath}.vo.ApiResult;
#if(${restControllerStyle})
import org.springframework.web.bind.annotation.RestController;
#else
import org.springframework.stereotype.Controller;
#end
#if(${superControllerClassPackage})
import ${superControllerClassPackage};
#end

/**
 * $!{table.comment} controller
 *
 * @author ${author}
 * @since ${date}
 */
#if(${restControllerStyle})
@RestController
#else
@Controller
#end
@RequestMapping("${sysModulePath}#if(${table.entityPath.startsWith("sys")})${table.entityPath.substring(3).substring(0,1).toLowerCase()}${table.entityPath.substring(3).substring(1)}#else${table.entityPath}#end")
#if(${kotlin})
class ${table.controllerName}#if(${superControllerClass}) : ${superControllerClass}()#end

#else
#if(${superControllerClass})
public class ${table.controllerName} extends ${superControllerClass} {
#else
public class ${table.controllerName} {
#end

    @Autowired
    private ${table.serviceName} i${entity}Service;

    /**
     * 查询$!{table.comment}（根据$!{table.comment}id）
     *
     * @param dto
     * @return ${packageParentPath}.vo.ApiResult<${packageParentPath}.entity${entityPackagePath}#if(${entity.toLowerCase().startsWith("sys")})${entity.toLowerCase().substring(3)}#else${entity.toLowerCase()}#end.${entity}>
     */
    @GetMapping("/getById")
    public ApiResult<${entity}> getById(IdDto dto) {
        if (ObjectUtils.isEmpty(dto.getId())) {
            return ApiResult.warn("id不能为空");
        }
        return ApiResult.success("查询成功", i${entity}Service.getById(dto.getId()));
    }
}

#end
